from datetime import date
from engine import should_use_tsp_ift

def test_no_ift_remaining():
    ok, reason = should_use_tsp_ift(
        today=date.today(),
        current_alloc={"G": 50, "C": 30, "I": 10, "S": 5, "F": 5},
        target_alloc={"G": 40, "C": 40, "I": 10, "S": 5, "F": 5},
        recent_regimes=["OPTIMIZED NEUTRAL"] * 3,
        recent_scores=[1, 1, 1],
        emergency_triggered=False,
        ift_count_this_month=2,
        last_ift_date=None,
        allow_second_ift=False,
        normal_drift_threshold_pct=7.5,
        score_change_threshold=3,
        confirmation_days=3,
        cooldown_days=5,
    )
    assert ok is False
    assert "No IFTs remaining" in reason
